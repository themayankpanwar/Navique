# ---- AI Travel Planner environment variables ----
# Copy this file to `.env` and fill in the values you need.
# NEVER commit your real `.env` file.

# --- Google Gemini (required for itinerary generation) ---
# When using the Supabase edge function, set these as Supabase edge function
# SECRETS (Project Settings -> Edge Functions -> Secrets), not in this file.
GEMINI_API_KEY=your-gemini-key-here
# Optional: pin a specific model. If unset, the backend auto-probes a list and
# uses the first model your key allows (gemini-2.5-flash-lite, gemini-2.5-flash, ...).
GEMINI_MODEL=

# --- OpenWeather (required for weather cards) ---
OPENWEATHER_API_KEY=your-openweather-key-here

# --- Backend / database (FastAPI local backend only) ---
DB_PATH=trips.db

# --- Frontend (Vite) ---
# These are auto-provisioned when using the Supabase-hosted backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Supabase's current "publishable" key belongs in VITE_SUPABASE_ANON_KEY.

# Optional override for the standalone FastAPI backend, e.g.
# VITE_API_BASE_URL=http://localhost:8000
